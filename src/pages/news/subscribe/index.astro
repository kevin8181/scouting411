---
import Layout from "@/components/layout/Layout.astro";
import { FeedManager } from "@/lib/news/feeds/feedManager";
import { faSquareUpRight } from "@fortawesome/free-solid-svg-icons";
import { FontAwesomeIcon } from "@fortawesome/react-fontawesome";
---

<Layout title="Subscribe with your Feed Reader">
	<div class="mx-auto flex w-full max-w-4xl flex-col gap-6 p-8">
		<p class="text-gray-8 text-sm">
			The original/upstream news sources we use are published in a variety of
			formats. For your convenience, Scouting411 parses and re-exports these
			sources as a set of standards-compliant, non-paginated web feeds for you.
			If you don't know what a web feed is, you can learn more at{" "}
			<a
				href="https://aboutfeeds.com/"
				rel="noopener noreferrer"
				target="_blank"
				class="text-blue wrap-anywhere hyphens-auto hover:underline"
				>aboutfeeds.com</a
			>.
		</p>

		<div class="border-gray-3 rounded-lg border bg-white p-4">
			<div class="text-gray-6 mb-2 text-xs font-medium uppercase">Caveats</div>
			<ul class="text-gray-8 flex flex-col gap-1.5 text-sm">
				<li class="flex gap-2">
					<span class="text-gray-4">&bull;</span>
					The feeds are not continuously updated. They may be stale by up to 24 hours
					at a given time.
				</li>
				<li class="flex gap-2">
					<span class="text-gray-4">&bull;</span>
					We have not added support for media enclosures; these feeds will not work
					with a podcast app.
				</li>
				<li class="flex gap-2">
					<span class="text-gray-4">&bull;</span>
					While we have attempted to faithfully represent the original content, the
					metadata and formatting of these feeds is not identical to the upstream
					sources.
				</li>
			</ul>
		</div>

		<div
			class="border-blue/30 bg-blue/5 flex flex-col items-start gap-2 rounded-lg border p-4 sm:flex-row sm:items-center sm:justify-between"
		>
			<div>
				<div class="text-gray-10 font-serif text-lg font-bold">
					Import All Feeds
				</div>
				<p class="text-gray-8 text-sm">
					Add every Scouting411 feed to your reader at once via OPML.
				</p>
			</div>
			<a
				href="/feeds/all/opml"
				rel="noopener noreferrer"
				target="_blank"
				class="bg-blue hover:bg-blue/90 flex items-center gap-2 rounded-md px-4 py-2 text-sm font-semibold whitespace-nowrap text-white"
			>
				Open OPML
				<FontAwesomeIcon icon={faSquareUpRight} height="0.9em" />
			</a>
		</div>

		<div class="border-gray-3 overflow-hidden rounded-lg border bg-white">
			<table class="w-full border-collapse text-sm">
				<thead>
					<tr class="border-gray-3 border-b bg-gray-50">
						<th class="text-gray-7 px-4 py-3 text-left font-medium">Source</th>
						<th class="text-gray-7 px-4 py-3 text-left font-medium">Feeds</th>
					</tr>
				</thead>
				<tbody>
					{
						FeedManager.feeds.map((feed) => (
							<tr class="border-gray-2 hover:bg-gray-1/60 border-b last:border-0">
								<td class="px-4 py-3">
									<a
										class="text-blue font-medium wrap-anywhere hyphens-auto hover:underline"
										href={feed.urls.overview}
									>
										{feed.name}
									</a>
								</td>
								<td class="px-4 py-3">
									<div class="flex gap-2">
										<a
											href={feed.urls.rss}
											rel="noopener noreferrer"
											target="_blank"
											class="border-gray-3 text-gray-8 hover:border-blue hover:text-blue rounded-md border px-2.5 py-1 text-xs font-medium transition-colors"
										>
											RSS
										</a>
										<a
											href={feed.urls.atom}
											rel="noopener noreferrer"
											target="_blank"
											class="border-gray-3 text-gray-8 hover:border-blue hover:text-blue rounded-md border px-2.5 py-1 text-xs font-medium transition-colors"
										>
											Atom
										</a>
									</div>
								</td>
							</tr>
						))
					}
				</tbody>
			</table>
		</div>
	</div>
</Layout>
