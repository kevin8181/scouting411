---
export const prerender = false;

import Layout from "@/components/layout/Layout.astro";
import { FeedManager } from "@/lib/news/feeds/feedManager";
---

<Layout title="News Sources">
	<div class="p-8">
		<div
			class="grid auto-rows-fr grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3"
		>
			{
				FeedManager.feeds.map(async (feed) => (
					<div class="border-gray-3 flex flex-col gap-1.5 rounded-lg border p-5">
						<a
							href={feed.urls.overview}
							class="text-blue font-serif text-xl font-bold hover:underline"
						>
							{feed.name}
						</a>
						<p class="text-sm">{feed.description}</p>
					</div>
				))
			}
		</div>
	</div>
</Layout>
