---
import RootLayout from "@/components/layout/RootLayout.astro";
import { AppShell } from "@/components/layout/sidebar/appShell";

const { title } = Astro.props;

export type Props = {
	title: string;
};
---

<RootLayout>
	<AppShell url={Astro.url} title={title} client:load>
		<slot />
	</AppShell>
</RootLayout>
