{
	"name": "scouting411",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.22.0",
	"engines": {
		"node": ">=22.13.0"
	},
	"engineStrict": true,
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "npx eslint \"src/**/*\"",
		"check": "npm run astro check && npm run format && npm run lint && npm run knip && echo '✅ All checks passed.'",
		"validateResourceLinks": "tsx scripts/validateResourceLinks.ts",
		"knip": "knip",
		"preinstall": "npx only-allow pnpm"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.7",
		"@astrojs/react": "^5.0.0",
		"@astrojs/sitemap": "^3.7.1",
		"@astrojs/vercel": "^10.0.0",
		"@fortawesome/fontawesome-svg-core": "^7.2.0",
		"@fortawesome/free-brands-svg-icons": "^7.2.0",
		"@fortawesome/free-solid-svg-icons": "^7.2.0",
		"@fortawesome/react-fontawesome": "^0.2.0",
		"@nanostores/persistent": "^1.3.3",
		"@tailwindcss/vite": "^4.2.1",
		"@upstash/redis": "^1.36.4",
		"astro": "^6.0.3",
		"feedsmith": "2.9.0",
		"he": "^1.2.0",
		"nanostores": "^1.1.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/he": "^1.2.3",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"eslint": "^10.0.3",
		"eslint-plugin-astro": "^1.6.0",
		"globals": "^17.4.0",
		"knip": "^5.86.0",
		"normalize-url": "^9.0.0",
		"only-allow": "^1.2.2",
		"prettier": "3.8.1",
		"prettier-plugin-astro": "0.14.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"tsx": "^4.21.0",
		"typescript-eslint": "^8.57.0"
	}
}
