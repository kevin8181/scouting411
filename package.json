{
	"name": "scouting411",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.22.0",
	"engines": {
		"node": ">=22.13.0"
	},
	"engineStrict": true,
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "pnpx eslint \"src/**/*\"",
		"check": "pnpm run astro check && pnpm run format && pnpm run lint && pnpm run knip && echo '✅ All checks passed.'",
